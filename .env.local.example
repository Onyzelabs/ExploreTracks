# ─── YouTube Data API v3 ─────────────────────────────────────────────────────
# Create a project at https://console.cloud.google.com
# Enable "YouTube Data API v3", then create an API Key (restrict to server IP in prod)
YOUTUBE_API_KEY=your_youtube_api_key_here

# ─── Movebank ────────────────────────────────────────────────────────────────
# Register at https://www.movebank.org, accept data terms for each study
# Basic Auth is sent as Authorization header: Basic base64(user:pass)
MOVEBANK_USERNAME=your_movebank_username
MOVEBANK_PASSWORD=your_movebank_password

# Comma-separated list of public Movebank study IDs to display
# Example studies (public, no auth required for some):
#   2911040  — Osprey Migration
#   21231406 — Savanna Elephant (Kruger NP)
#   9651291  — Hudson Bay Polar Bear
MOVEBANK_STUDY_IDS=2911040,21231406,9651291

# ─── explore.org ─────────────────────────────────────────────────────────────
# Base URL — change to staging URL if needed
EXPLORE_ORG_BASE_URL=https://explore.org

# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
