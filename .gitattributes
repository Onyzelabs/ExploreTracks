# Normalize line endings to LF in the repository
* text=auto eol=lf

# Explicitly declare text files
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.json text eol=lf
*.css text eol=lf
*.md text eol=lf
*.mjs text eol=lf
*.env.example text eol=lf

# Binary files — never modify
*.ico binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.svg text eol=lf
